rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Only the authenticated owner can access their personalized data
    match /daily_recovery_snapshot/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only backend scripts write
    }
    
    match /daily_subjective_checkin/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // User writes their checkins
    }
  }
}
