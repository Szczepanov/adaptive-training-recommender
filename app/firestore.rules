rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Legacy recovery snapshot collection (backend-write only, readable by authenticated users)
    match /daily_recovery_snapshot/{date} {
      allow read: if request.auth != null;
      allow write: if false; // Only backend scripts write
    }
    
    // Legacy flat check-in collection (preserved for backward compatibility)
    match /daily_subjective_checkin/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Writes must go through user-scoped Phase 4 path
    }
    
    // Phase 4 User-owned collections with explicit scoping
    
    // Daily subjective check-ins (user-owned)
    match /users/{userId}/daily_subjective_checkins/{date} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Goals (user-owned)
    match /users/{userId}/goals/{goalId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Constraints (user-owned)
    match /users/{userId}/constraints/{constraintId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Preferences (singleton, user-owned)
    match /users/{userId}/preferences/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Daily recovery snapshots (user-owned for consistency)
    match /users/{userId}/daily_recovery_snapshots/{date} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
